# ─────────────────────────────────────────────────────────────
# Nornicel R&D Knowledge Graph — environment template
# Copy to `.env` and fill in. Never commit the real .env.
# ─────────────────────────────────────────────────────────────

# --- Neo4j (graph store) ---
# For a 2-day sprint the fastest path is Neo4j Aura Free (cloud, no install):
#   https://neo4j.com/cloud/aura-free/  -> create instance -> copy URI + password
# Local alternative: Neo4j Desktop (bolt://localhost:7687)
NEO4J_URI=neo4j+s://XXXXXXXX.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me
NEO4J_DATABASE=neo4j

# --- LLM (провайдер-агностичный слой: извлечение + NL→Cypher + синтез) ---
# Основной провайдер — YandexGPT (официальный OpenAI-совместимый эндпоинт).
LLM_PROVIDER=yandex
LLM_API_BASE=https://llm.api.cloud.yandex.net/v1
LLM_API_KEY=                      # API-ключ Yandex AI Studio
YC_FOLDER_ID=                     # Folder ID Yandex Cloud
# LLM_MODEL можно не задавать — для yandex соберётся как gpt://<folder>/yandexgpt/latest.
# Для скорости можно указать yandexgpt-lite. Для другого провайдера задайте модель явно.
# LLM_MODEL=

# --- Эмбеддинги (семантический поиск) ---
EMBED_PROVIDER=local_e5           # локальная multilingual-e5 (офлайн); опция: yandex
EMBED_MODEL=intfloat/multilingual-e5-large

# --- Django backend ---
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Разрешённые origin фронтенда (React/Vite dev-сервер):
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
